# Site (MF Advocacia)
MF_SITE_URL=https://mfadvocacia.api.br
MF_BRAND_NAME="MF Advocacia"
MF_ENVIRONMENT=production

# n8n (public URL used by frontend)
N8N_PUBLIC_BASE_URL=https://n8n.mfadvocacia.api.br
N8N_LEAD_WEBHOOK_PATH=/webhook/site-lead
N8N_CHAT_WEBHOOK_PATH=/webhook/senne-site
N8N_SENNE_ENTRADA_WEBHOOK_PATH=/webhook/senne-entrada

# Optional local override for static preview (python -m http.server)
# Example: http://localhost:5678
N8N_PUBLIC_BASE_URL_LOCAL=http://localhost:5678

# SENNE / Ollama (internal use inside n8n Docker network)
OLLAMA_INTERNAL_URL=http://ollama:11434
OLLAMA_TEXT_MODEL=qwen2.5:7b
OLLAMA_VISION_MODEL=moondream:latest

